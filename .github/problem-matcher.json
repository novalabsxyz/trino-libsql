{
  "problemMatcher": [
    {
      "owner": "maven",
      "pattern": [
        {
          "regexp": "^\\[(?:ERROR|WARNING)\\]\\s+(.+?):\\[?(\\d+)(?:,(\\d+))?\\]?\\s+(?:error|warning)?:?\\s*(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      ]
    }
  ]
}
